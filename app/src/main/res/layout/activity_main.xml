<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dash_bg"
    tools:context=".activities.MainActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Top App Bar (Static) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingHorizontal="15dp"
            android:background="@color/dash_bg"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivMenu"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_menu_hamburger"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/dash_icon_tint"
                android:contentDescription="Menu" />

            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="12dp"
                android:src="@drawable/scholaria_logo"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/ivMenu"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@null" />

            <TextView
                android:id="@+id/tvAppTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SCHOLARIA"
                android:textColor="@color/dash_text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/ivSearch"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_search_custom"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/dash_icon_tint" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Sub Navigation Bar (Static) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/navContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/topBar">

            <LinearLayout
                android:id="@+id/subNavBar"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp">

                <ImageView android:id="@+id/navHome" style="@style/SubNavIcon" android:src="@drawable/ic_nav_dashboard" />
                <ImageView android:id="@+id/navCourses" style="@style/SubNavIcon" android:src="@drawable/ic_nav_courses" />
                <ImageView android:id="@+id/navTasks" style="@style/SubNavIcon" android:src="@drawable/ic_nav_tasks" />
                <ImageView android:id="@+id/navMessages" style="@style/SubNavIcon" android:src="@drawable/ic_nav_messages" />
                <ImageView android:id="@+id/navNotifications" style="@style/SubNavIcon" android:src="@drawable/ic_nav_notifications" />
                <ImageView android:id="@+id/navProfile" style="@style/SubNavIcon" android:src="@drawable/ic_nav_profile" />
            </LinearLayout>

            <!-- The Sliding Indicator -->
            <View
                android:id="@+id/navIndicator"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:background="@drawable/sub_nav_selected_bg"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:id="@+id/navDivider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/dash_teal"
            app:layout_constraintTop_toBottomOf="@id/navContainer" />

        <!-- ViewPager for Content (Sliding) -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/mainViewPager"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/navDivider" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/drawer_menu"
        android:background="@color/dash_bg"
        app:itemTextColor="@color/dash_text_primary"
        app:itemIconTint="@color/dash_icon_tint" />

</androidx.drawerlayout.widget.DrawerLayout>
