<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="176dp"
    android:background="@color/primary_dark"
    android:gravity="bottom"
    android:orientation="vertical"
    android:padding="16dp"
    android:theme="@style/ThemeOverlay.AppCompat.Dark">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivProfileImage"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/scholaria_logo"
        app:shapeAppearanceOverlay="@style/CircleAppearance"
        android:padding="2dp"
        app:strokeColor="@color/dash_teal"
        app:strokeWidth="2dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Scholarian User"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="student@scholaria.edu.ph"
        android:textColor="@color/status_card_text_secondary"
        android:textSize="14sp" />

</LinearLayout>
