<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glow / Background Highlight -->
    <item android:top="4dp" android:bottom="6dp" android:left="4dp" android:right="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#1A00D1A0" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <!-- Sharp Green Underline -->
    <item android:gravity="bottom" android:height="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/dash_teal" />
        </shape>
    </item>
</layer-list>
